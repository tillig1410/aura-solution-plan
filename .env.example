# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_ENDPOINT=https://app.yourdomain.com/api/v1/webhooks/stripe

# Telnyx
TELNYX_API_KEY=KEY_xxx
TELNYX_PUBLIC_KEY=xxx
TELNYX_FROM_NUMBER=+1xxxxxxxxxx

# WhatsApp
WHATSAPP_VERIFY_TOKEN=xxx
WHATSAPP_APP_SECRET=xxx
WHATSAPP_ACCESS_TOKEN=xxx
WHATSAPP_PHONE_NUMBER_ID=xxx

# Messenger
MESSENGER_VERIFY_TOKEN=xxx
MESSENGER_APP_SECRET=xxx
MESSENGER_PAGE_ACCESS_TOKEN=xxx

# Telegram
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_WEBHOOK_SECRET=xxx

# n8n
N8N_WEBHOOK_URL=http://localhost:5678/webhook/booking-conversation
# Production: N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/booking-conversation
# REQUIRED for docker-compose — will fail to start if missing
N8N_DOMAIN=localhost
# Dev only — binds n8n port to localhost (remove in production)
N8N_DEV_PORT=127.0.0.1:5678

# Redis
# REQUIRED for docker-compose — will fail to start if missing
REDIS_URL=redis://:YOUR_STRONG_PASSWORD_HERE@localhost:6379
REDIS_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# Google AI (Gemini — used via n8n)
GOOGLE_AI_API_KEY=xxx

# Let's Encrypt (production only)
# CERTBOT_EMAIL=admin@yourdomain.com
